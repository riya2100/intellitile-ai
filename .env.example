# TileGenius — Environment Variables
# Copy this file to .env and fill in your values
#
# Windows: copy .env.example .env
# Mac/Linux: cp .env.example .env

# ── Database ────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/tilgenius

# ── OpenAI (via Replit AI Integrations proxy in cloud) ─────────
# When running locally, use your own OpenAI key
OPENAI_API_KEY=sk-your-openai-api-key-here

# For Replit AI Integrations proxy (already set in Replit environment)
# AI_INTEGRATIONS_OPENAI_BASE_URL=https://...
# AI_INTEGRATIONS_OPENAI_API_KEY=...

# ── App ─────────────────────────────────────────────────────────
NODE_ENV=development

# API server port (default: 8080)
PORT=8080

# Session secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=your-session-secret-here-change-this

# ── Frontend ─────────────────────────────────────────────────────
# Vite dev server port (default: 3000)
VITE_PORT=3000

# API base URL for local dev (frontend calls this)
VITE_API_BASE_URL=http://localhost:8080
